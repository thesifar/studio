
{
  "entities": {
    "Bhajan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bhajan",
      "type": "object",
      "description": "Represents an individual audio or video bhajan, including its metadata and content links.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Bhajan entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the bhajan."
        },
        "description": {
          "type": "string",
          "description": "A detailed, thematic description of the bhajan, potentially generated by AI."
        },
        "audioUrl": {
          "type": "string",
          "description": "The URL to the audio file for the bhajan (if it's an audio bhajan).",
          "format": "uri"
        },
        "videoUrl": {
          "type": "string",
          "description": "The URL to the video file for the bhajan (if it's a video bhajan).",
          "format": "uri"
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "The URL to a thumbnail image representing the bhajan.",
          "format": "uri"
        },
        "artist": {
          "type": "string",
          "description": "The name of the artist/singer."
        },
        "category": {
          "type": "string",
          "description": "The devotional theme or category."
        },
        "language": {
          "type": "string",
          "description": "The language of the bhajan."
        },
        "type": {
          "type": "string",
          "enum": ["audio", "video"]
        },
        "duration": {
          "type": "string",
          "description": "The duration of the bhajan (MM:SS)."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["title", "artist", "type", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "type": "object",
      "description": "A user-submitted bhajan awaiting review.",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "category": { "type": "string" },
        "language": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "video"] },
        "url": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/bhajans/{bhajanId}": {
      "schema": "Bhajan",
      "description": "Publicly readable collection of verified bhajans."
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "User submissions awaiting admin approval."
    },
    "/roles_admin/{userId}": {
      "schema": "object",
      "description": "Admin privileges mapping."
    }
  }
}
