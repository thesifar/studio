rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared helper for admin check
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // Bhajans: Publicly searchable and readable
    match /bhajans/{bhajanId} {
      allow get, list: if true;
      allow create: if true; // Allow public submissions
      allow update, delete: if isAdmin();
    }

    // Metadata Collections: Publicly readable for filtering
    match /artists/{artistId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /languages/{languageId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /themes/{themeId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Admin Roles: Restricted access
    match /admin_roles/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Submissions: Public creation, admin management
    match /submissions/{submissionId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }
    
    // Deployment Fingerprint: 20240522-1645-EXPLICIT-LIST
  }
}