rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Core content collections are publicly readable for browsing and playback
    // We explicitly separate 'get' and 'list' to ensure collection queries are allowed.
    
    match /bhajans/{bhajanId} {
      allow get, list: if true;
      allow create: if true; // Allow public submissions for the prototype
      allow update, delete: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /artists/{artistId} {
      allow get, list: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    match /languages/{languageId} {
      allow get, list: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    match /themes/{themeId} {
      allow get, list: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /admin_roles/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)));
      allow list: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /submissions/{submissionId} {
      allow create: if true;
      allow get, list, update, delete: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if false;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Deployment Fingerprint: 20240523-2045-EXPLICIT-GET-LIST-STABLE
  }
}