rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * REFRESH V4 - EXPLICIT PUBLIC READ ACCESS
 * 
 * This ruleset explicitly separates 'get' and 'list' operations to ensure
 * unauthenticated users can browse the collection without permission errors.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Admin Check
    function isUserAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // 1. PUBLIC CONTENT COLLECTIONS
    // These matches apply to both document gets and collection lists.
    
    match /bhajans/{bhajanId} {
      // Explicitly allow public reading (browsing and viewing)
      allow get, list: if true;
      // Writing is reserved for administrators
      allow create, update, delete: if isUserAdmin();
    }
    
    match /artists/{artistId} {
      allow get, list: if true;
      allow write: if isUserAdmin();
    }
    
    match /languages/{languageId} {
      allow get, list: if true;
      allow write: if isUserAdmin();
    }
    
    match /themes/{themeId} {
      allow get, list: if true;
      allow write: if isUserAdmin();
    }

    // 2. ADMINISTRATIVE ACCESS CONTROL (DBAC)
    
    match /admin_roles/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isUserAdmin());
      allow list, write: if isUserAdmin();
    }

    // 3. USER SUBMISSIONS
    // Allow public creation (submissions) but private review.
    
    match /submissions/{submissionId} {
      allow create: if true; 
      allow get, list, update, delete: if isUserAdmin();
    }
    
    // 4. USER PROFILES
    
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if false;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}