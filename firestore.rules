rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * REFRESH V8 - RESOLVING LIST PERMISSIONS
 * 
 * Deployment Refresh Token: 2024-03-21T11:45:00Z
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Admin Check
    function isUserAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // 1. PUBLIC CONTENT COLLECTIONS
    // Using 'read' shorthand to explicitly permit both 'get' and 'list' operations for all users.
    
    match /bhajans/{bhajanId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /languages/{languageId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /themes/{themeId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    // 2. ADMINISTRATIVE ACCESS CONTROL (DBAC)
    
    match /admin_roles/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isUserAdmin());
      allow list, write: if isUserAdmin();
    }

    // 3. USER SUBMISSIONS
    
    match /submissions/{submissionId} {
      allow create: if true; 
      allow read, write: if isUserAdmin();
    }
    
    // 4. USER PROFILES
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}