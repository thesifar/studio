rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * 
 * This configuration ensures public access for browsing (list) and individual 
 * document retrieval (get), while restricting management to administrators.
 * 
 * Deployment Fingerprint: SEED_DATA_RECOVERY_2024_03_22_T16_30
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is an admin
    function isUserAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "admin@bhajansangam.com"
      );
    }

    // 1. PUBLIC CONTENT COLLECTIONS
    // Explicitly allowing 'list' for collection queries and 'get' for individual items.
    
    match /bhajans/{bhajanId} {
      allow get, list: if true;
      allow write: if isUserAdmin() || request.auth != null; // Relaxed for initial prototype seeding
    }
    
    match /artists/{artistId} {
      allow get, list: if true;
      allow write: if isUserAdmin();
    }
    
    match /languages/{languageId} {
      allow get, list: if true;
      allow write: if isUserAdmin();
    }
    
    match /themes/{themeId} {
      allow get, list: if true;
      allow write: if isUserAdmin();
    }

    // 2. ADMINISTRATIVE ACCESS CONTROL (DBAC)
    
    match /admin_roles/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isUserAdmin());
      allow list, write: if isUserAdmin();
    }

    // 3. USER SUBMISSIONS
    
    match /submissions/{submissionId} {
      allow create: if true; 
      allow read, write: if isUserAdmin();
    }
    
    // 4. USER PROFILES
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}