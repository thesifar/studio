rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * FORCED BACKEND SECURITY CONTEXT REFRESH
 * 
 * This update ensures that collection-level 'list' operations are correctly
 * propagated to the production backend for unauthenticated users.
 * 
 * Deployment Fingerprint: REFRESH_FORCE_BHAKTI_PULSE_2024_03_22_T15_45
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is an admin
    function isUserAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // 1. PUBLIC CONTENT COLLECTIONS
    // Using 'read' shorthand to explicitly cover both 'get' and 'list' operations.
    // This allows unauthenticated users to browse the full collection.
    
    match /bhajans/{bhajanId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /languages/{languageId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /themes/{themeId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    // 2. ADMINISTRATIVE ACCESS CONTROL (DBAC)
    
    match /admin_roles/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isUserAdmin());
      allow list, write: if isUserAdmin();
    }

    // 3. USER SUBMISSIONS
    
    match /submissions/{submissionId} {
      allow create: if true; 
      allow read, write: if isUserAdmin();
    }
    
    // 4. USER PROFILES
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}