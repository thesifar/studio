
rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * 
 * Deployment Fingerprint: BHAJAN_SEEDING_PERMISSIVE_V201
 * This configuration allows public writes to the bhajans collection 
 * specifically to facilitate prototype seeding and testing.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is an admin
    function isUserAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "admin@bhajansangam.com"
      );
    }

    // 1. BHAJANS COLLECTION
    // Permissive read and write for the prototype/seeding phase
    match /bhajans/{bhajanId} {
      allow read: if true;
      allow write: if true; 
    }
    
    // 2. OTHER CONTENT COLLECTIONS
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isUserAdmin() || request.auth != null;
    }
    
    match /languages/{languageId} {
      allow read: if true;
      allow write: if isUserAdmin() || request.auth != null;
    }
    
    match /themes/{themeId} {
      allow read: if true;
      allow write: if isUserAdmin() || request.auth != null;
    }

    // 3. ADMINISTRATIVE & SYSTEM COLLECTIONS
    match /admin_roles/{userId} {
      allow read: if request.auth != null;
      allow write: if isUserAdmin();
    }

    match /submissions/{submissionId} {
      allow create: if true; 
      allow read, write: if isUserAdmin() || request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global fallback
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null || isUserAdmin();
    }
  }
}
