
rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * 
 * Deployment Fingerprint: REFRESH_CONTEXT_AUTH_V102
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is an admin
    function isUserAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "admin@bhajansangam.com" ||
        request.auth.token.firebase.sign_in_provider == 'anonymous' // Allow anonymous for prototype dashboard
      );
    }

    // 1. BHAJANS COLLECTION
    match /bhajans/{bhajanId} {
      allow read: if true;
      allow write: if true; // Fully open for prototype seeding
    }
    
    // 2. OTHER CONTENT COLLECTIONS
    match /artists/{artistId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /languages/{languageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /themes/{themeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. ADMINISTRATIVE & SYSTEM COLLECTIONS
    match /admin_roles/{userId} {
      allow get: if request.auth != null;
      allow list, write: if request.auth != null;
    }

    match /submissions/{submissionId} {
      allow create: if true; 
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global fallback
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
