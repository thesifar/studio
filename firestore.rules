rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * 
 * Simplified for prototype development to ensure seamless browsing and seeding.
 * 
 * Deployment Fingerprint: REFRESH_SECURITY_CONTEXT_FINAL_V2
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is an admin
    function isUserAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "admin@bhajansangam.com"
      );
    }

    // 1. PUBLIC CONTENT COLLECTIONS
    // Explicitly allowing all read and write operations for Bhajans to facilitate seeding
    match /bhajans/{bhajanId} {
      allow read, write: if true;
    }
    
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isUserAdmin() || request.auth != null;
    }
    
    match /languages/{languageId} {
      allow read: if true;
      allow write: if isUserAdmin() || request.auth != null;
    }
    
    match /themes/{themeId} {
      allow read: if true;
      allow write: if isUserAdmin() || request.auth != null;
    }

    // 2. ADMINISTRATIVE & SYSTEM COLLECTIONS
    
    match /admin_roles/{userId} {
      allow get: if request.auth != null;
      allow list, write: if isUserAdmin() || request.auth != null;
    }

    match /submissions/{submissionId} {
      allow create: if true; 
      allow read, write: if isUserAdmin() || request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global fallback
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}