rules_version = '2';

/**
 * BHAJAN SANGAM - FIRESTORE SECURITY RULES
 * 
 * This ruleset implements public read access for devotional content (bhajans, artists, etc.)
 * while restricting management operations to administrators identified via the admin_roles collection.
 * 
 * Deployment Hash: 20240523-2200-FINAL-PUBLIC-LIST-FIX
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. PUBLIC CONTENT COLLECTIONS
    // Everyone (including unauthenticated users) can browse and view content.
    
    match /bhajans/{bhajanId} {
      allow get, list: if true;
      allow create: if true; 
      allow update, delete: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    match /artists/{artistId} {
      allow get, list: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    match /languages/{languageId} {
      allow get, list: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    match /themes/{themeId} {
      allow get, list: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // 2. ADMINISTRATIVE ACCESS CONTROL (DBAC)
    
    match /admin_roles/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)));
      allow list: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // 3. USER SUBMISSIONS
    
    match /submissions/{submissionId} {
      allow create: if true; // Allow anonymous contributions
      allow get, list, update, delete: if request.auth != null && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }
    
    // 4. USER PROFILES
    
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if false;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}